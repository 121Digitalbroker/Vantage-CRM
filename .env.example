# true = dummy leads in browser (assignment always works). false = Supabase only (set RLS in supabase-rls-leads.sql).
VITE_USE_DEMO_LEADS=true
VITE_USE_DEMO_USERS=false

# Supabase Configuration
# Get these values from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key for admin operations (keep secret!)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
